---
import Layout from '../layouts/main-layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Mini Demo Day #1 -- Biere & Code"
  description="Welcome to the first Mini Demo Day! A night of demos, drinks, and good vibes."
>
  <Header />

  <div class="flex flex-col items-center justify-center min-h-screen pt-28 pb-20 px-8 md:px-16 bg-white text-[#1a1a1a]">
    <div class="flex flex-col items-center gap-8 max-w-3xl text-center">
      <img
        src="/logo.svg"
        alt="Biere & Code Logo"
        width="80"
        height="80"
        loading="eager"
        class="opacity-0 animate-[fadeIn_0.6s_ease-out_forwards]"
      />

      <div class="space-y-5 opacity-0 animate-[fadeIn_0.6s_ease-out_0.2s_forwards]">
        <p class="text-sm uppercase tracking-[0.3em] text-[#cc6c11] font-semibold">March 19, 2026</p>
        <h1 class="font-grotesk font-bold text-[#1a1a1a] text-4xl md:text-5xl leading-[1.1]">
          Welcome to the First<br />Mini Demo Day
        </h1>
        <p class="text-gray-500 max-w-2xl mx-auto leading-relaxed text-lg">
          Grab a beer, find a seat, and get ready for some <span class="font-semibold text-[#cc6c11]">cool demos</span> from the community.
        </p>
      </div>

      <div class="mt-4 opacity-0 animate-[fadeIn_0.6s_ease-out_0.4s_forwards]">
        <div class="inline-flex items-center gap-3 bg-gray-50 rounded-full px-8 py-4 border border-gray-100">
          <span class="font-grotesk font-medium text-[#1a1a1a]">Demos &middot; Drinks &middot; Good Vibes</span>
        </div>
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-center gap-4 md:gap-5 mt-12 opacity-0 animate-[fadeIn_0.6s_ease-out_0.6s_forwards]">
      <a
        href="https://www.meetup.com/biere-code-beer-paris/"
        class="inline-block bg-[#1a1a1a] hover:bg-[#333] text-white font-semibold px-10 py-4 rounded-full transition-all duration-200 hover:scale-[1.02]"
        target="_blank"
        rel="noopener noreferrer"
      >
        Join us on Meetup
      </a>
      <a
        href="/"
        class="inline-block border border-gray-200 hover:border-gray-300 text-[#1a1a1a] font-semibold px-10 py-4 rounded-full transition-all duration-200"
      >
        bierecode.com
      </a>
    </div>
  </div>

  <Footer />
</Layout>
