---
import Layout from '../layouts/main-layout.astro';
import { AIOrchestrationPage } from '../components/pages/ai-orchestration/ai-orchestration';
import Footer from '../components/Footer.astro';

const title = 'Bière & Code: AI Orchestration in Paris';
const description = 'A new Bière & Code event in planning for people interested in AI orchestration, agents, workflows, and evaluation in Paris.';
const image = '/og-image.png';
---

<Layout title={title} description={description} image={image}>
  <AIOrchestrationPage client:load>
    <Footer />
  </AIOrchestrationPage>
</Layout>
