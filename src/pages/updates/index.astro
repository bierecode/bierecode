---
import Layout from '../../layouts/main-layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allUpdates = await getCollection('updates');
const sortedUpdates = allUpdates.sort((a, b) => {
  return b.data.published.getTime() - a.data.published.getTime();
});

const updates = await Promise.all(sortedUpdates.map(async (update) => {
  const { Content } = await update.render();
  return { update, Content };
}));

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  }).format(date);
}
---

<Layout
  title="Community Updates - Biere & Code Paris"
  description="Stay in the loop with the latest announcements, event recaps, and community highlights straight from the Biere Code crew."
>
  <Header activePage="updates" />

  <section class="min-h-screen bg-white pt-28 pb-20 px-6">
    <div class="max-w-3xl mx-auto space-y-10 md:space-y-12">
      <header class="text-center space-y-4">
        <p class="uppercase tracking-[0.3em] text-xs text-[#cc6c11] font-semibold">Biere & Code</p>
        <h1 class="font-bold text-[#1a1a1a] leading-[1.4] font-grotesk text-3xl md:text-4xl">Community Updates</h1>
        <p class="text-gray-500 max-w-2xl mx-auto leading-relaxed">
          Stay in the loop with the latest announcements, event recaps, and community highlights.
        </p>
      </header>

      {updates.length === 0 ? (
        <p class="text-center text-gray-500">No updates yet. Check back soon!</p>
      ) : (
        <div class="space-y-6">
          {updates.map(({ update, Content }) => (
            <article class="relative rounded-2xl bg-white shadow-[0_4px_20px_-4px_rgba(0,0,0,0.08)] border border-gray-100 overflow-hidden hover:shadow-[0_8px_30px_-4px_rgba(0,0,0,0.12)] hover:-translate-y-0.5 transition-all duration-200 group">
              <div class="block p-6 md:p-8 space-y-4">
                <div class="flex flex-wrap items-start justify-between gap-4">
                  <div class="space-y-2">
                    <span class={`inline-flex items-center px-3 py-1 text-xs font-semibold tracking-wide uppercase rounded-full ${update.data.type === 'event' ? 'bg-blue-50 text-blue-600' : 'bg-[#cc6c11]/10 text-[#cc6c11]'}`}>
                      {update.data.type === 'event' ? 'Event' : 'Post'}
                    </span>
                    <h2 class="text-xl font-semibold text-[#1a1a1a]">
                      <a href={`/updates/${update.slug}`} class="before:absolute before:inset-0 focus:outline-none">
                        {update.data.title}
                      </a>
                    </h2>
                  </div>
                  <div class="text-right text-xs text-gray-400 space-y-1">
                    <p>Published {formatDate(update.data.published)}</p>
                    {update.data.updated && update.data.updated.getTime() !== update.data.published.getTime() && (
                      <p>Updated {formatDate(update.data.updated)}</p>
                    )}
                  </div>
                </div>
                <div class="prose prose-sm max-w-none text-gray-500 prose-headings:font-bold prose-headings:text-[#1a1a1a] prose-a:text-[#cc6c11] prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl prose-a:relative prose-a:z-10">
                  <Content />
                </div>
                {update.data.type === 'event' && update.data.event && (
                  <div class="bg-gray-50 border border-gray-100 text-[#1a1a1a] text-sm rounded-xl px-4 py-3 space-y-1 relative z-10">
                    {(update.data.event.date || update.data.event.time) && (
                      <p>
                        <strong class="font-semibold">When:</strong> {[update.data.event.date, update.data.event.time].filter(Boolean).join(' - ')}
                      </p>
                    )}
                    {update.data.event.location && (
                      <p>
                        <strong class="font-semibold">Where:</strong> {update.data.event.location}
                      </p>
                    )}
                    {update.data.event.duration && (
                      <p>
                        <strong class="font-semibold">Duration:</strong> {update.data.event.duration}
                      </p>
                    )}
                  </div>
                )}
                {update.data.tags && update.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 pt-1 relative z-10">
                    {update.data.tags.map((tag) => (
                      <span class="text-xs uppercase tracking-wide bg-gray-100 text-gray-500 px-3 py-1 rounded-full">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      )}
      <Footer />
    </div>
  </section>
</Layout>
