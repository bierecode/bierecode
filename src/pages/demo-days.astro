---
import Layout from '../layouts/main-layout.astro';
import Header from '../components/Header.astro';
---

<Layout
  title="Demo Days - January 2026"
  description="Join us for our Demo Day in January 2026! Show off your cool projects and connect with other developers."
>
  <Header />

  <div class="flex flex-col items-center justify-center min-h-screen pt-28 pb-20 px-8 md:px-16 bg-white text-[#1a1a1a]">
    <div class="flex flex-col items-center gap-8 max-w-3xl text-center">
      <img
        src="/logo.svg"
        alt="Biere Code Logo"
        width="80"
        height="80"
        loading="eager"
        class="opacity-0 animate-[fadeIn_0.6s_ease-out_forwards]"
      />
      <div class="space-y-5">
        <p class="text-sm uppercase tracking-[0.3em] text-[#cc6c11] font-semibold">Coming Soon</p>
        <h1 class="font-grotesk font-bold text-[#1a1a1a] text-4xl md:text-5xl leading-[1.1]">Demo Days - January 2026</h1>
        <p class="text-gray-500 max-w-2xl mx-auto leading-relaxed text-lg">
          We are excited to announce that we will be hosting a <span class="font-semibold text-[#cc6c11]">Demo Day</span> in January 2026! This event is an opportunity for developers to showcase the innovative projects and cool stuff they have been working on.
        </p>
        <p class="text-gray-500 max-w-xl mx-auto leading-relaxed">We don't have a date yet, but stay tuned for more information coming soon!</p>
      </div>
    </div>
    <div class="flex flex-col md:flex-row items-center gap-4 md:gap-5 mt-10">
      <a
        href="https://www.meetup.com/biere-code-beer-paris/"
        class="inline-block bg-[#1a1a1a] hover:bg-[#333] text-white font-semibold px-10 py-4 rounded-full transition-all duration-200 hover:scale-[1.02]"
        target="_blank"
        rel="noopener noreferrer"
      >
        Join our Meetup
      </a>
      <a
        href="/updates"
        class="inline-block border border-gray-200 hover:border-gray-300 text-[#1a1a1a] font-semibold px-10 py-4 rounded-full transition-all duration-200"
      >
        See Updates
      </a>
    </div>
  </div>
</Layout>
